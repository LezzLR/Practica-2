@model IEnumerable<Practica_2.Models.Curso>

@{
    ViewData["Title"] = "Panel del Coordinador";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Panel del Coordinador</h1>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Nuevo Curso
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Código</th>
                    <th>Nombre</th>
                    <th class="text-center">Créditos</th>
                    <th class="text-center">Cupo Máximo</th>
                    <th>Horario</th>
                    <th class="text-center">Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var curso in Model)
                {
                    <tr class="@(curso.Activo ? "" : "table-secondary text-muted")">
                        <td><strong>@curso.Codigo</strong></td>
                        <td>@curso.Nombre</td>
                        <td class="text-center">@curso.Creditos</td>
                        <td class="text-center">@curso.CupoMaximo</td>
                        <td>@curso.HorarioInicio.ToString(@"hh\:mm") - @curso.HorarioFin.ToString(@"hh\:mm")</td>
                        <td class="text-center">
                            @if (curso.Activo)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactivo</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center">
                                <a asp-action="Edit" asp-route-id="@curso.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                                <a asp-action="Matriculas" asp-route-id="@curso.Id" class="btn btn-sm btn-outline-info">Matrículas</a>
                                <form asp-action="Desactivar" asp-route-id="@curso.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm @(curso.Activo ? "btn-outline-warning" : "btn-outline-success")"
                                            onclick="return confirm('@(curso.Activo ? "¿Desactivar" : "¿Activar") el curso @curso.Codigo?')">
                                        @(curso.Activo ? "Desactivar" : "Activar")
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
