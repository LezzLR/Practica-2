@model IEnumerable<Practica_2.Models.Matricula>

@{
    ViewData["Title"] = "Matrículas del Curso";
    var curso = ViewBag.Curso as Practica_2.Models.Curso;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-0">Matrículas del Curso</h1>
        <p class="text-muted mb-0">@curso?.Codigo - @curso?.Nombre</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary">← Volver al Panel</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Usuario</th>
                        <th>Fecha Registro</th>
                        <th class="text-center">Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var matricula in Model)
                    {
                        <tr>
                            <td>@matricula.Usuario?.Email</td>
                            <td>@matricula.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-center">
                                @switch (matricula.Estado)
                                {
                                    case Practica_2.Models.EstadoMatricula.Pendiente:
                                        <span class="badge bg-warning text-dark">Pendiente</span>
                                        break;
                                    case Practica_2.Models.EstadoMatricula.Confirmada:
                                        <span class="badge bg-success">Confirmada</span>
                                        break;
                                    case Practica_2.Models.EstadoMatricula.Cancelada:
                                        <span class="badge bg-danger">Cancelada</span>
                                        break;
                                }
                            </td>
                            <td class="text-center">
                                <div class="d-flex gap-1 justify-content-center">
                                    @if (matricula.Estado != Practica_2.Models.EstadoMatricula.Confirmada)
                                    {
                                        <form asp-action="Confirmar" asp-route-id="@matricula.Id" method="post">
                                            <button type="submit" class="btn btn-sm btn-success"
                                                    onclick="return confirm('¿Confirmar esta matrícula?')">
                                                ✓ Confirmar
                                            </button>
                                        </form>
                                    }
                                    @if (matricula.Estado != Practica_2.Models.EstadoMatricula.Cancelada)
                                    {
                                        <form asp-action="Cancelar" asp-route-id="@matricula.Id" method="post">
                                            <button type="submit" class="btn btn-sm btn-danger"
                                                    onclick="return confirm('¿Cancelar esta matrícula?')">
                                                ✗ Cancelar
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="p-4 text-center text-muted">
                <p>No hay matrículas registradas para este curso.</p>
            </div>
        }
    </div>
</div>
