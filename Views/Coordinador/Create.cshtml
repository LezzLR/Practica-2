@model Practica_2.Models.Curso

@{
    ViewData["Title"] = "Nuevo Curso";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0">Crear Nuevo Curso</h4>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="All" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Codigo" class="form-label"></label>
                        <input asp-for="Codigo" class="form-control" placeholder="Ej. CS201" />
                        <span asp-validation-for="Codigo" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label"></label>
                        <input asp-for="Nombre" class="form-control" placeholder="Ej. Algoritmos Avanzados" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Creditos" class="form-label"></label>
                            <input asp-for="Creditos" class="form-control" type="number" min="1" />
                            <span asp-validation-for="Creditos" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="CupoMaximo" class="form-label"></label>
                            <input asp-for="CupoMaximo" class="form-control" type="number" min="1" />
                            <span asp-validation-for="CupoMaximo" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="HorarioInicio" class="form-label"></label>
                            <input asp-for="HorarioInicio" class="form-control" type="time" />
                            <span asp-validation-for="HorarioInicio" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="HorarioFin" class="form-label"></label>
                            <input asp-for="HorarioFin" class="form-control" type="time" />
                            <span asp-validation-for="HorarioFin" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                        <button type="submit" class="btn btn-success">Crear Curso</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
